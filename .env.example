# ───────────────────────────────────────────────────────
# Required on Railway → Variables panel
# ───────────────────────────────────────────────────────

# Random secrets (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please-replace-me-with-32-plus-random-chars
ADMIN_JWT_SECRET=please-replace-me-with-a-different-32-plus-random-chars

# First-time admin (only used on cold start — change immediately)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeOnFirstLogin!
ADMIN_DISPLAY_NAME=HR Admin

# Optional — defaults shown
PORT=3000
NODE_ENV=production
EXAM_DURATION_SEC=1800
MAX_LISTENS_PER_AUDIO=2

# Writing-track rubric grader (AWS Bedrock). Required for the writing
# track to score automatically — without it, every submitted exam is flagged
# as pending_review and must be graded by an HR admin in /admin.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# CORS origins (comma-separated). Leave empty to allow same-origin only.
# When the frontend is hosted on a separate domain, set this.
ALLOWED_ORIGINS=

# Where SQLite DB and bank.json live. Mount a Railway Volume here.
DATA_DIR=/app/data
